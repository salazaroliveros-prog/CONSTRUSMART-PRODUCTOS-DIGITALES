# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CRM Configuration
VITE_CRM_API_ID=your_crm_api_id
CRM_API_KEY=your_crm_api_key

# Application Configuration
VITE_APP_URL=https://your-domain.com
VITE_APP_NAME=Construsmart

# Email Configuration (Resend or similar)
EMAIL_API_KEY=your_email_service_api_key
EMAIL_FROM_ADDRESS=noreply@your-domain.com

# Admin Configuration
VITE_ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD_HASH=your_hashed_admin_password

# Feature Flags
ENABLE_CUSTOMER_PORTAL=true
ENABLE_REVIEWS=true
ENABLE_REFERRALS=true
ENABLE_PROMO_CODES=true

# Analytics
GOOGLE_ANALYTICS_ID=your_google_analytics_id
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000